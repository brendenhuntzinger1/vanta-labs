# Card checkout gateway:
#   live (default) - the seam a real high-risk processor plugs into. Inert
#     until a real integration is registered, so production never invents a
#     "paid" state. Connecting your processor = set the keys below + swap this
#     to your provider name; checkout logic is untouched.
#   mock - a simulated sandbox gateway for development/testing. Card checkout
#     redirects to an internal /pay/mock page where a payment can be approved
#     or declined, driving the real webhook pipeline with FAKE money so the
#     whole order lifecycle (paid → email → inventory → commission → refund)
#     can be tested end to end. Never charges a real card. Do NOT use in prod.
PAYMENT_PROVIDER=live
PAYMENT_SECRET_KEY=
PAYMENT_PUBLIC_KEY=
# HMAC secret the processor (and the mock gateway) sign webhook events with.
# In mock mode a fixed dev value is used automatically if this is blank.
PAYMENT_WEBHOOK_SECRET=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_ENABLE_ANALYTICS=false
COMMISSION_HOLD_DAYS=14

# Admin console second factor. After the correct username + password, the admin
# must also enter a 6-digit passcode before a session is issued. Set a
# per-account passcode from the admin Team page (preferred), or set this global
# 6-digit fallback here to enforce the second factor for every admin at once.
# If BOTH are unset, the passcode step is not yet provisioned and login falls
# back to username + password only (so a fresh deployment is never locked out).
ADMIN_ACCESS_CODE=

# Scheduled jobs. Vercel Cron hits /api/cron/sweep (membership billing +
# abandoned-cart recovery emails) and must send this as
# "Authorization: Bearer $CRON_SECRET". If unset, the cron route returns 401
# and those scheduled jobs never run.
CRON_SECRET=

# Recurring subscription (membership) billing backend:
#   noop (default) - records intent but never charges, until a real recurring
#     processor is connected.
#   mock - simulated recurring charges for testing the full subscription
#     state machine (intro charge, renewals, dunning/past-due) with fake money.
#     A charge succeeds unless the stored payment method marks a decline test
#     card. Never charges a real card; do NOT use in production.
BILLING_PROVIDER=noop

# Transactional email (contact form, order confirmations, ambassador
# emails, etc.) - see src/lib/email/ and README-partner-portal.md for setup.
# EMAIL_PROVIDER selects the backend: smtp (default) | resend | sendgrid.
# Delivery is NOT claimed working until one of these is fully configured -
# an unconfigured/misconfigured provider fails the send safely without
# blocking whatever triggered it (an order, an approval, etc.).
# Master on/off switch for all outbound email. Leave blank/false to keep
# email disabled (sends are safely skipped) until a provider is configured.
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
EMAIL_FROM=

# Secret used to sign one-click unsubscribe links. Falls back to
# SUPABASE_SERVICE_ROLE_KEY if unset; set a dedicated value in production.
UNSUBSCRIBE_SECRET=

# smtp provider (also used for AWS SES - point SMTP_HOST at your SES SMTP
# endpoint and use your SES SMTP credentials)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# resend provider
RESEND_API_KEY=

# sendgrid provider
SENDGRID_API_KEY=

# 3PL / fulfillment provider (optional; stays in "manual" mode until set).
# When your 3PL is connected, set these; paid orders are then transmitted
# automatically and the inbound status webhook is verified with the secret.
FULFILLMENT_API_KEY=
FULFILLMENT_WEBHOOK_SECRET=

# Legacy aliases (not used directly in code)
SUPABASE_URL=
SUPABASE_ANON_KEY=

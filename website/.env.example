PAYMENT_PROVIDER=live
PAYMENT_SECRET_KEY=
PAYMENT_PUBLIC_KEY=
PAYMENT_WEBHOOK_SECRET=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_ENABLE_ANALYTICS=false
COMMISSION_HOLD_DAYS=14

# Transactional email (contact form, order confirmations, ambassador
# emails, etc.) - see src/lib/email/ and README-partner-portal.md for setup.
# EMAIL_PROVIDER selects the backend: smtp (default) | resend | sendgrid.
# Delivery is NOT claimed working until one of these is fully configured -
# an unconfigured/misconfigured provider fails the send safely without
# blocking whatever triggered it (an order, an approval, etc.).
EMAIL_PROVIDER=smtp
EMAIL_FROM=

# smtp provider (also used for AWS SES - point SMTP_HOST at your SES SMTP
# endpoint and use your SES SMTP credentials)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# resend provider
RESEND_API_KEY=

# sendgrid provider
SENDGRID_API_KEY=

# Optional checkout pricing modifiers
NEXT_PUBLIC_SERVICE_FEE_RATE=0.05

# Legacy aliases (not used directly in code)
SUPABASE_URL=
SUPABASE_ANON_KEY=
